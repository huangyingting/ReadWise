{
  "name": "readwise",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "node-ts": "node --env-file-if-exists=.env --experimental-strip-types --import ./scripts/register-ts.mjs",
    "test": "NODE_ENV=test node --env-file-if-exists=.env --experimental-strip-types --import ./scripts/register-ts.mjs --no-warnings --experimental-test-module-mocks --test \"tests/**/*.test.ts\"",
    "coverage:node": "node --experimental-strip-types --import ./scripts/register-ts.mjs --no-warnings scripts/check-node-coverage.ts",
    "test:db": "NODE_ENV=test RUN_DB_INTEGRATION=1 node --env-file-if-exists=.env --experimental-strip-types --import ./scripts/register-ts.mjs --no-warnings --experimental-test-module-mocks --test-concurrency=1 --test \"tests/db/**/*.test.ts\"",
    "test:e2e:smoke": "playwright test --config=playwright.config.ts",
    "scrape": "npm run node-ts -- scripts/scrape.ts",
    "scrape-review": "npm run node-ts -- scripts/scrape-review.ts",
    "process": "npm run node-ts -- scripts/process.ts",
    "worker": "npm run node-ts -- scripts/worker.ts",
    "seed": "npm run node-ts -- scripts/seed.ts",
    "eval": "npm run node-ts -- --no-warnings scripts/eval.ts",
    "db:migrate": "prisma migrate deploy && prisma generate",
    "db:reset": "prisma migrate reset --force --skip-seed && prisma generate",
    "push-reminders": "npm run node-ts -- scripts/push-reminders.ts",
    "scrape:smithsonian": "npm run node-ts -- scripts/scrape-smithsonian.ts",
    "scrape:undark": "npm run node-ts -- scripts/scrape-undark.ts",
    "smithsonian:reset-scrape-analyze": "npm run db:reset && npm run scrape:smithsonian -- --limit 50 --target-saved --publish",
    "analyze:speech-alignment": "NODE_ENV=test npm run node-ts -- --no-warnings scripts/analyze-speech-alignment.ts",
    "prisma:generate": "prisma generate",
    "prisma:generate:pg": "prisma generate --schema prisma/postgresql/schema.prisma",
    "prisma:migrate:pg": "prisma migrate deploy --schema prisma/postgresql/schema.prisma",
    "postinstall": "prisma generate",
    "migrate-storage": "npm run node-ts -- scripts/migrate-storage.ts",
    "migrate-speech-timing": "npm run node-ts -- scripts/migrate-speech-timing.ts",
    "speech:batch": "npm run node-ts -- scripts/batch-synthesis.ts",
    "schema:generate": "node --import ./scripts/register-ts.mjs --experimental-strip-types --no-warnings scripts/generate-schemas.ts",
    "schema:check-parity": "node --experimental-strip-types --no-warnings scripts/check-schema-parity.ts",
    "api-catalog": "node --experimental-strip-types --import ./scripts/register-ts.mjs --no-warnings scripts/generate-api-catalog.ts",
    "dict:prune": "npm run node-ts -- scripts/prune-local-dictionary.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@azure/storage-blob": "^12.32.0",
    "@mozilla/readability": "^0.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.205.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^6.2.1",
    "@types/sanitize-html": "^2.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "franc-min": "^6.2.0",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.21.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "natural": "^8.1.1",
    "next": "^15.1.4",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.17.5",
    "tailwind-merge": "^3.6.0",
    "undici": "^7.28.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.5",
    "@types/react-dom": "^19.0.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.4",
    "prisma": "^6.2.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.3"
  }
}
