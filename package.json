{
  "name": "readwise",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test node --experimental-strip-types --import ./scripts/register-ts.mjs --no-warnings --experimental-test-module-mocks --test \"tests/**/*.test.ts\"",
    "test:db": "NODE_ENV=test RUN_DB_INTEGRATION=1 node --experimental-strip-types --import ./scripts/register-ts.mjs --no-warnings --experimental-test-module-mocks --test \"tests/db/**/*.test.ts\"",
    "test:e2e:smoke": "playwright test --config=playwright.config.ts",
    "scrape": "node --experimental-strip-types --import ./scripts/register-ts.mjs scripts/scrape.ts",
    "process": "node --experimental-strip-types --import ./scripts/register-ts.mjs scripts/process.ts",
    "worker": "node --experimental-strip-types --import ./scripts/register-ts.mjs scripts/worker.ts",
    "seed": "node --experimental-strip-types --import ./scripts/register-ts.mjs scripts/seed.ts",
    "push-reminders": "node --experimental-strip-types --import ./scripts/register-ts.mjs scripts/push-reminders.ts",
    "prisma:generate": "prisma generate",
    "prisma:generate:pg": "prisma generate --schema prisma/postgresql/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:pg": "prisma migrate deploy --schema prisma/postgresql/schema.prisma",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.2.1",
    "@types/sanitize-html": "^2.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "next": "^15.1.4",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.17.5",
    "tailwind-merge": "^3.6.0",
    "undici": "^7.28.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.5",
    "@types/react-dom": "^19.0.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.4",
    "prisma": "^6.2.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.3"
  }
}
