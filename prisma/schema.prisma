generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  Admin
  Reader
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(Reader)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  profile         Profile?
  readingProgress ReadingProgress[]
  savedWords      SavedWord[]
  dailyActivities DailyActivity[]
  readingLists    ReadingList[]
}

model Profile {
  id           String    @id @default(cuid())
  userId       String    @unique
  ageRange     String?
  gender       String?
  englishLevel String
  topics       String    @default("[]")
  completedAt  DateTime?
  dailyGoal    Int       @default(2)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Article {
  id              String    @id @default(cuid())
  slug            String?   @unique
  title           String
  author          String?
  source          String?
  sourceUrl       String?
  heroImage       String?
  excerpt         String?
  content         String
  category        String?
  wordCount       Int?
  readingMinutes  Int?
  difficulty      String?
  difficultyScore Float?
  status          String    @default("published")
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  readingProgress ReadingProgress[]
  translations    Translation[]
  vocabulary      VocabularyItem[]
  quizQuestions   QuizQuestion[]
  speech          ArticleSpeech?
  tags            ArticleTag[]
  readingListItems ReadingListItem[]

  @@index([category])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
  @@index([articleId])
}

model ArticleSpeech {
  id          String   @id @default(cuid())
  articleId   String   @unique
  voice       String
  format      String
  mimeType    String
  audioBase64 String
  spokenText  String
  words       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model QuizQuestion {
  id           String   @id @default(cuid())
  articleId    String
  question     String
  options      String
  correctIndex Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, question])
  @@index([articleId])
}

model VocabularyItem {
  id          String   @id @default(cuid())
  articleId   String
  word        String
  explanation String
  example     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, word])
  @@index([articleId])
}

model SavedWord {
  id             String    @id @default(cuid())
  userId         String
  word           String
  explanation    String?
  example        String?
  articleId      String?
  dueAt          DateTime?
  intervalDays   Int       @default(0)
  easeFactor     Float     @default(2.5)
  repetitions    Int       @default(0)
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId])
}

model DailyActivity {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime
  articlesRead Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Translation {
  id         String   @id @default(cuid())
  articleId  String
  targetLang String
  content    String
  model      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, targetLang])
  @@index([articleId])
}

model ReadingProgress {
  id          String    @id @default(cuid())
  userId      String
  articleId   String
  percent     Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ReadingList {
  id        String   @id @default(cuid())
  userId    String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ReadingListItem[]

  @@index([userId])
}

model ReadingListItem {
  id        String   @id @default(cuid())
  listId    String
  articleId String
  addedAt   DateTime @default(now())

  list    ReadingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  article Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([listId, articleId])
  @@index([articleId])
}
