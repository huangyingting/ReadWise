# ReadWise environment variables
# Copy this file to .env and fill in real values.
# Never commit .env or any file containing real secrets.

# =============================================================================
# Database (required)
# =============================================================================

# Prisma datasource URL.
# Default local workflow still uses SQLite.
# Production-parity PostgreSQL workflow:
#   npm run local:pg:setup
#   DATABASE_URL="postgresql://readwise:readwise-dev-password@localhost:55432/readwise?schema=public"
#   PRISMA_SCHEMA_PATH="prisma/postgresql/schema.prisma"
# Production deployments should set a managed PostgreSQL URL with real
# credentials via the host secret manager; never commit those values.
DATABASE_URL="file:./dev.db"

# Prisma schema path used by runtime readiness/migration checks.
# Keep the default for SQLite; set to prisma/postgresql/schema.prisma whenever
# DATABASE_URL points at PostgreSQL.
PRISMA_SCHEMA_PATH="prisma/schema.prisma"

# =============================================================================
# NextAuth (required)
# =============================================================================

# Random secret used to sign session tokens.
# Generate one with: openssl rand -hex 32
# Startup validation rejects placeholders and values shorter than 32 characters.
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Public URL of the application (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# OAuth providers (optional — at least one needed for user sign-in)
# Features that require a logged-in user will be unavailable without a provider.
# =============================================================================

# Google OAuth 2.0
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000/api/auth/callback/google to Authorised Redirect URIs.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Azure Entra ID (AAD) OAuth
# Register an app at https://portal.azure.com -> App registrations.
# Set AZURE_AD_TENANT_ID="common" for multi-tenant (personal + work accounts).
AZURE_AD_CLIENT_ID="your-azure-ad-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-ad-client-secret"
AZURE_AD_TENANT_ID="your-tenant-id-or-common"

# =============================================================================
# Azure OpenAI (optional)
# Enables: translation, vocabulary extraction, comprehension quiz, tag generation,
# difficulty assessment, and article summarisation.
# When absent, all AI features degrade gracefully (placeholder / heuristic fallback).
# =============================================================================

# Azure OpenAI resource endpoint (no trailing slash)
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com"

# Azure OpenAI API key
AZURE_OPENAI_API_KEY="your-azure-openai-api-key"

# Deployment/model name (must be created in the Azure OpenAI Studio)
AZURE_OPENAI_DEPLOYMENT="gpt-4o-mini"

# API version — check Azure docs for the latest stable version
AZURE_OPENAI_API_VERSION="2025-04-01-preview"

# Optional request tuning. Malformed values fall back to defaults and appear as
# readiness warnings instead of breaking startup.
AI_REQUEST_TIMEOUT_MS="30000"
AI_MAX_RETRIES="2"

# =============================================================================
# Azure Speech (optional)
# Enables: text-to-speech narration with word-level timing highlights.
# When absent, the narration panel shows a friendly "not configured" message.
# =============================================================================

# Azure Speech resource key
AZURE_SPEECH_KEY="your-azure-speech-key"

# Azure region where the Speech resource is deployed (e.g. eastus, japaneast)
AZURE_SPEECH_REGION="eastus"

# Neural TTS voice name (see https://learn.microsoft.com/azure/ai-services/speech-service/language-support)
AZURE_SPEECH_VOICE="en-US-AndrewMultilingualNeural"

# Output audio format (mp3 recommended for broad compatibility)
AZURE_SPEECH_OUTPUT_FORMAT="audio-24khz-96kbitrate-mono-mp3"

# Optional synthesis timeout. Malformed values fall back to the default.
SPEECH_TIMEOUT_MS="30000"

# =============================================================================
# Web Push / VAPID (optional)
# Enables: SRS review reminder push notifications.
# Leave all three blank to disable. Partial or malformed values are reported as
# readiness degradation and push delivery remains a no-op.
# =============================================================================

# Web Push / VAPID — for SRS review reminders (run `npm run generate-vapid` to generate)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# =============================================================================
# Tuning (optional — sensible defaults built in)
# =============================================================================

# Server-side log level: debug | info | warn | error  (default: info)
LOG_LEVEL="info"

# AI endpoint rate limiting per authenticated user
# Maximum number of AI requests allowed per window  (default: 20)
RATE_LIMIT_AI_REQUESTS="20"
# Maximum lookup requests allowed per window        (default: 60)
RATE_LIMIT_LOOKUP_REQUESTS="60"
# Maximum public requests allowed per window        (default: 30)
RATE_LIMIT_PUBLIC_REQUESTS="30"
# Length of the rate-limit window in milliseconds    (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS="60000"

# Dictionary lookup backend.
# - local  = use bundled local JSON dictionaries in ./dict (no external lookup)
# - free   = use https://dictionaryapi.dev (legacy network-backed behavior)
# - hybrid = local first, then free as fallback
DICTIONARY_PROVIDER="local"
# Local dictionary directory, relative to project root unless absolute.
LOCAL_DICTIONARY_DIR="dict"
# Local dictionary language: en for English definitions, cn/zh for Chinese definitions.
LOCAL_DICTIONARY_LANGUAGE="en"

# AI budgets / quotas (RW-022) — cap AI provider usage for cost control.
# Counted over AI_QUOTA_WINDOW_MS. Leave a knob UNSET (or <= 0) to disable that
# cap (unlimited) — with none set, no AI quotas are enforced (dev/CI default).
#   - Interactive (user API) calls enforce: per-user + per-feature + global.
#   - Background (worker/seed/processor) calls enforce: per-feature + background.
# Window over which AI quotas are counted, in ms           (default: 86400000 = 24h)
AI_QUOTA_WINDOW_MS="86400000"
# Max interactive AI calls per user per window             (default: unlimited)
AI_QUOTA_USER_DAILY=""
# Max interactive AI calls across all users per window     (default: unlimited)
AI_QUOTA_GLOBAL_DAILY=""
# Max background/worker AI calls per window                (default: unlimited)
AI_QUOTA_BACKGROUND_DAILY=""
# Default per-feature AI call cap per window               (default: unlimited)
AI_QUOTA_FEATURE_DEFAULT_DAILY=""
# Per-feature override: AI_QUOTA_FEATURE_<FEATURE>_DAILY (FEATURE upper-cased,
# non-alphanumerics → "_"). Examples:
# AI_QUOTA_FEATURE_TRANSLATION_DAILY="500"
# AI_QUOTA_FEATURE_SENTENCE_TRANSLATION_DAILY="1000"

# =============================================================================
# Feature kill switches (optional — default enabled)
# Set to "false" or "0" to intentionally disable a feature even when its
# provider credentials are configured. Disabled state degrades identically to
# unconfigured: no throws, same graceful fallback path, no behavior change when
# the variable is absent or set to "true"/"1"/"on".
# =============================================================================
# AI (chat completions, translation, quiz, vocabulary, summarisation)
FEATURE_AI_ENABLED="true"
# Text-to-speech / TTS (Azure Speech narration and word timing)
FEATURE_TTS_ENABLED="true"
# Web Push notifications (VAPID push delivery)
FEATURE_PUSH_ENABLED="true"
# Web scraper (article import and background crawl trigger)
FEATURE_SCRAPER_ENABLED="true"
# Scraper multi-strategy fetch fallback chain (for bot-blocked provider pages).
# On a bot-challenge status (401/403/429/451/503) the GET fetch falls back
# through: rotating browser/bot UA+header profiles, the r.jina.ai reader proxy,
# then a Wayback Machine snapshot. Genuine 404/410 never trigger fallback. Each
# stage has its own kill-switch (default ON); set to "false" to disable.
SCRAPER_FETCH_PROFILE_RETRY="true"
SCRAPER_FETCH_READER="true"
SCRAPER_FETCH_WAYBACK="true"
# Optional API key for the r.jina.ai reader proxy. The reader fallback works
# without it (lower rate limits); set it for higher limits/reliability.
JINA_API_KEY=""
# Today Session learner workflow (/today route, Dashboard Today card, default learner landing)
FEATURE_TODAY_SESSION_ENABLED="true"
