# ReadWise environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# =============================================================================
# Database (required)
# =============================================================================

# Prisma datasource URL.
# For local development, a relative SQLite path is fine.
# For Docker / production, use an absolute path to a mounted volume
# (e.g. file:/data/readwise.db).
DATABASE_URL="file:./dev.db"

# =============================================================================
# NextAuth (required)
# =============================================================================

# Random secret used to sign session tokens.
# Generate one with: openssl rand -hex 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Public URL of the application (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# OAuth providers (optional — at least one needed for user sign-in)
# Features that require a logged-in user will be unavailable without a provider.
# =============================================================================

# Google OAuth 2.0
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000/api/auth/callback/google to Authorised Redirect URIs.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Azure Entra ID (AAD) OAuth
# Register an app at https://portal.azure.com -> App registrations.
# Set AZURE_AD_TENANT_ID="common" for multi-tenant (personal + work accounts).
AZURE_AD_CLIENT_ID="your-azure-ad-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-ad-client-secret"
AZURE_AD_TENANT_ID="your-tenant-id-or-common"

# =============================================================================
# Azure OpenAI (optional)
# Enables: translation, vocabulary extraction, comprehension quiz, tag generation,
# difficulty assessment, and article summarisation.
# When absent, all AI features degrade gracefully (placeholder / heuristic fallback).
# =============================================================================

# Azure OpenAI resource endpoint (no trailing slash)
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com"

# Azure OpenAI API key
AZURE_OPENAI_API_KEY="your-azure-openai-api-key"

# Deployment/model name (must be created in the Azure OpenAI Studio)
AZURE_OPENAI_DEPLOYMENT="gpt-4o-mini"

# API version — check Azure docs for the latest stable version
AZURE_OPENAI_API_VERSION="2025-04-01-preview"

# =============================================================================
# Azure Speech (optional)
# Enables: text-to-speech narration with word-level timing highlights.
# When absent, the narration panel shows a friendly "not configured" message.
# =============================================================================

# Azure Speech resource key
AZURE_SPEECH_KEY="your-azure-speech-key"

# Azure region where the Speech resource is deployed (e.g. eastus, japaneast)
AZURE_SPEECH_REGION="eastus"

# Neural TTS voice name (see https://learn.microsoft.com/azure/ai-services/speech-service/language-support)
AZURE_SPEECH_VOICE="en-US-AndrewMultilingualNeural"

# Output audio format (mp3 recommended for broad compatibility)
AZURE_SPEECH_OUTPUT_FORMAT="audio-24khz-96kbitrate-mono-mp3"

# =============================================================================
# Tuning (optional — sensible defaults built in)
# =============================================================================

# Server-side log level: debug | info | warn | error  (default: info)
LOG_LEVEL="info"

# AI endpoint rate limiting per authenticated user
# Maximum number of AI requests allowed per window  (default: 20)
RATE_LIMIT_AI_REQUESTS="20"
# Length of the rate-limit window in milliseconds    (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS="60000"
